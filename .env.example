# --- Database (async URL for SQLAlchemy) — the only name the app and Alembic use ---
# Must match docker-compose.yml POSTGRES_* (or your server). Encode special chars in password:
# e.g. Root123! → Root123%21   (@ → %40  # → %23)
SUPABASE_DATABASE_URL=postgresql+asyncpg://compliance:compliance@localhost:5432/compliance

# --- LLM via OpenRouter (OpenAI-compatible API for chat + embeddings) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional OpenRouter headers (see https://openrouter.ai/docs)
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_X_TITLE=Compliance AI

# Resolve LLM API key as: OPENROUTER_API_KEY || OPENAI_API_KEY (fallback for dev)
# Primary chat model id on OpenRouter (examples: openai/gpt-4.1-mini, anthropic/claude-3.5-sonnet)
LLM_MODEL=openai/gpt-4.1-mini
# Legacy alias for the same setting:
# AGENT_MODEL=openai/gpt-4.1-mini

# Embeddings model id on OpenRouter (OpenAI-style slug)
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- OpenAI platform only (Agents SDK trace export — https://platform.openai.com/logs/trace ) ---
# Use a separate key here so chat/embeddings stay on OpenRouter; tracing uploads to OpenAI.
OPENAI_API_KEY=sk-...

# --- Langfuse (optional) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- API (used by Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# --- Clerk (required — get from https://dashboard.clerk.com)
# Used by Next (NEXT_PUBLIC_* / CLERK_SECRET_KEY) and FastAPI (CLERK_JWKS_URL).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# JWT / JWKS for backend API verification (Dashboard → Configure → API keys → Frontend API → JWKS URL)
CLERK_JWKS_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/Dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/Dashboard
